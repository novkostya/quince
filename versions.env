# quince — single source of truth for toolchain versions AND container image refs.
#
# Consumed in exactly one place each:
#   - Makefile     `include versions.env`  → runs every gate inside these images
#   - Dockerfile   via `--build-arg` passed by the Makefile (defaults mirror these)
#   - CI           passes the same build-args
#
# The dev host is a pure container host (no toolchains installed anywhere): dev, CI, and
# the release image therefore compile with byte-identical toolchains. Bumps land HERE.
# Stack canon: docs/quince.stack.md D10/D11/D13, program doc "Where work runs".
#
# ONE Alpine line — 3.24 — across build and runtime (Operator ruling): the usbmuxd daemon
# is only packaged at 3.24+, and a single Alpine minor across every stage is one fewer
# place for behaviour to diverge. `-alpine3.24` variants exist only on current language
# lines, so the toolchain pins track "latest stable" (D11): Go 1.26, Node 22 LTS, Rust 1.
# The one exception is uv: astral publishes no `-alpine3.XX` tag, so its stage is built
# FROM alpine:3.24 with the uv binary copied in (see the Dockerfile toolchain-uv stage).

# --- Versions (human-facing pins) ---
GO_VERSION=1.26.5
GOLANGCI_LINT_VERSION=2.12.2
NODE_VERSION=22.23.1
PNPM_VERSION=9.15.0
PYTHON_VERSION=3.12
UV_VERSION=0.5.11
ALPINE_VERSION=3.24
NETMUXD_REF=v0.4.3

# --- Toolchain images (gate containers == production Dockerfile build stages) ---
# All on Alpine 3.24/musl so the containerized gates and the shipped binary share a libc.
GO_IMAGE=golang:1.26.5-alpine3.24
NODE_IMAGE=node:22.23.1-alpine3.24
RUST_IMAGE=rust:1.97.1-alpine3.24
ALPINE_IMAGE=alpine:3.24
# uv has no -alpine3.24 variant; toolchain-uv is built FROM alpine:3.24 and copies this
# static uv binary in, keeping the python gate on the same Alpine line as everything else.
UV_IMAGE=ghcr.io/astral-sh/uv:0.5.11-python3.12-alpine
# Playwright e2e runner: the official image (glibc + browsers preinstalled) per the qn.0
# ruling — musl is irrelevant inside it. Tag tracks @playwright/test in ui/package.json.
PLAYWRIGHT_IMAGE=mcr.microsoft.com/playwright:v1.61.1-noble
